# -----------------------------------------------------------------------
# Backend environment variables
# Copy to .env and fill in real values. Never commit .env to git.
# -----------------------------------------------------------------------

# Server
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=false

# Database (Timescale Cloud connection string parts)
DATABASE=tsdb
DATABASE_USERNAME=tsdbadmin
DATABASE_PASSWORD=your-timescale-cloud-password
DATABASE_HOST=your-project.tsdb.cloud.timescale.com
DATABASE_PORT=5432
DATABASE_DRIVER=postgresql+psycopg2

# Redis / Valkey (Upstash or other managed Redis)
VALKEY_SCHEME=rediss
VALKEY_HOST=your-upstash-endpoint.upstash.io
VALKEY_PORT=6379
VALKEY_DB=0

# Security — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=replace-with-a-real-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_HOUR=24
REMEMBER_ME_EXPIRE_DAY=30

# Frontend origin (used in email links and CORS)
FRONTEND_URL=https://your-app.vercel.app
ALLOWED_ORIGIN=["https://your-app.vercel.app"]

# Email (Resend)
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=noreply@yourdomain.com

# Fundamentals data source (Financial Modeling Prep — Starter tier)
# https://site.financialmodelingprep.com/developer/docs
FMP_API_KEY=your_fmp_api_key
